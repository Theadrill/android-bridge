{
  "name": "android-bridge",
  "displayName": "Android Remote Bridge",
  "description": "Ponte de comunicação para entrada de texto via Android",
  "version": "1.0.0",
  "publisher": "antigravity",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "android-bridge.start",
        "title": "Start Android Bridge"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.80.0",
    "eslint": "^8.41.0"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "clipboardy": "^5.3.1",
    "formidable": "^3.5.4",
    "node-window-manager": "^2.2.4",
    "ws": "^8.13.0"
  }
}
